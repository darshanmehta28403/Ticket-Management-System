# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://admin:admin123@localhost:5432/ticketdb?schema=public"

# Use a long, random value outside local development.
JWT_SECRET="replace-with-a-long-random-secret"

# Comma-separated browser origins permitted to call the API.
CORS_ORIGINS="http://localhost:4000,http://127.0.0.1:5500,http://localhost:3000"
PORT=3000
